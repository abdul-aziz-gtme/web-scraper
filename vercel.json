{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "builds": [
    { "src": "api/index.ts", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/health/?", "dest": "/api/index?__health=1" },
    { "src": "/api/health/?", "dest": "/api/index?__health=1" },
    { "src": "/(.+\\..+)", "dest": "/api/index?domain=$1" },
    { "src": "/(.*)", "dest": "/api/index" }
  ]
}
