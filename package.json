{
  "name": "techstack-detector",
  "version": "0.1.0",
  "private": true,
  "description": "Free tech-stack detection API (TypeScript on Cloudflare Workers) for cold-outbound enrichment via Clay",
  "type": "module",
  "scripts": {
    "verify": "tsx src/cli/verify.ts",
    "build:fingerprints": "tsx build/build-fingerprints.ts",
    "fetch:db": "tsx build/fetch-db.ts",
    "test": "tsx --test src/**/*.test.ts",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "dev:vercel": "vercel dev",
    "deploy:vercel": "vercel deploy --prod"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240909.0",
    "@types/node": "^22.19.20",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "wrangler": "^3.78.0"
  }
}
