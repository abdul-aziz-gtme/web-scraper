# The hosted API only needs api/ + src/core/. Keep everything else out of the
# deployment bundle so uploads stay small. (Vercel detects the runtime from the
# git source, so the real fix for Python mis-detection is keeping requirements.txt
# out of the repo ROOT — it now lives in tools/ — not just ignoring it here.)
.tmp/
tools/
workflows/
build/
.wrangler/
node_modules/
*.py
.env
.env.example
credentials.json
token.json
src/cli/
src/worker/
**/*.test.ts
