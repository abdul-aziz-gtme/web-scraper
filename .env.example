# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# Optional: default User-Agent string for scraping requests.
SCRAPER_USER_AGENT="Mozilla/5.0 (compatible; WAT-Scraper/1.0; +https://example.com/bot)"

# Optional: seconds to wait between requests (politeness / rate-limit safety).
SCRAPER_REQUEST_DELAY=1.0

# Optional: request timeout in seconds.
SCRAPER_TIMEOUT=20

# Add API keys for any paid services here as you integrate them, e.g.:
# SCRAPINGBEE_API_KEY=
# OPENAI_API_KEY=
